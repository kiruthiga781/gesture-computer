<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="GestureSpeak – gesture-controlled communication for speech-impaired users" />
  <title>GestureSpeak</title>

  <!-- Tabler Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.19.0/dist/tabler-icons.min.css" />

  <!-- MediaPipe Hands (WASM, runs fully in browser) -->
  <script src="https://cdn.jsdelivr.net/npm/@mediapipe/camera_utils/camera_utils.js" crossorigin="anonymous"></script>
  <script src="https://cdn.jsdelivr.net/npm/@mediapipe/drawing_utils/drawing_utils.js" crossorigin="anonymous"></script>
  <script src="https://cdn.jsdelivr.net/npm/@mediapipe/hands/hands.js" crossorigin="anonymous"></script>

  <link rel="stylesheet" href="css/main.css" />
  <link rel="manifest" href="manifest.json" />
</head>
<body>

  <!-- ── Sidebar Nav ── -->
  <nav id="sidebar" aria-label="Main navigation">
    <div class="brand">
      <i class="ti ti-hand-stop" aria-hidden="true"></i>
      <span>GestureSpeak</span>
    </div>
    <ul class="nav-links">
      <li><a href="index.html" class="active" aria-current="page"><i class="ti ti-message-circle"></i> Communicate</a></li>
      <li><a href="pages/trainer.html"><i class="ti ti-settings-2"></i> Gesture Trainer</a></li>
      <li><a href="pages/phrases.html"><i class="ti ti-list"></i> Phrase Library</a></li>
      <li><a href="pages/caregiver.html"><i class="ti ti-users"></i> Caregiver View</a></li>
      <li><a href="pages/history.html"><i class="ti ti-clock"></i> History</a></li>
      <li><a href="pages/settings.html"><i class="ti ti-settings"></i> Settings</a></li>
    </ul>
    <div class="nav-footer">
      <span id="camera-status" class="status-dot off"></span>
      <span id="camera-status-label">Camera off</span>
    </div>
  </nav>

  <!-- ── Main ── -->
  <main id="main-content">

    <!-- Top bar -->
    <header class="topbar">
      <button id="menu-toggle" class="icon-btn" aria-label="Toggle menu">
        <i class="ti ti-menu-2"></i>
      </button>
      <h1 class="page-title">Communicate</h1>
      <div class="topbar-right">
        <button id="emergency-btn" class="emergency-btn" aria-label="Emergency alert">
          <i class="ti ti-alert-triangle"></i> Emergency
        </button>
      </div>
    </header>

    <!-- Camera + gesture area -->
    <section class="cam-section" aria-label="Camera and gesture detection">
      <div class="cam-wrap" id="cam-wrap">
        <video id="cam" autoplay playsinline muted aria-label="Camera feed"></video>
        <canvas id="gesture-canvas"></canvas>

        <div id="cam-overlay" class="cam-overlay">
          <button id="start-cam-btn" class="start-cam-btn">
            <i class="ti ti-camera"></i>
            <span>Enable Camera</span>
            <small>Gesture detection uses your webcam locally. No data is sent anywhere.</small>
          </button>
        </div>

        <div class="cam-hud" id="cam-hud" hidden>
          <div class="gesture-pill" id="gesture-pill">
            <i class="ti ti-hand-stop"></i>
            <span id="gesture-name">Waiting…</span>
          </div>
          <div class="confidence-wrap">
            <div class="confidence-bar" id="confidence-bar" style="width:0%"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Output message -->
    <section class="output-section" aria-label="Composed message">
      <div class="output-header">
        <span class="section-label">Composed message</span>
        <span id="word-count" class="badge">0 words</span>
      </div>
      <div class="output-box" id="output-box" role="log" aria-live="polite" aria-label="Output message">
        <span class="placeholder">Your message will appear here…</span>
      </div>
      <div class="output-actions">
        <button class="btn btn-primary" id="speak-btn"><i class="ti ti-volume"></i> Speak</button>
        <button class="btn btn-secondary" id="copy-btn"><i class="ti ti-copy"></i> Copy</button>
        <button class="btn btn-secondary" id="clear-btn"><i class="ti ti-trash"></i> Clear</button>
        <button class="btn btn-secondary" id="undo-btn"><i class="ti ti-arrow-back-up"></i> Undo</button>
      </div>
    </section>

    <!-- Quick phrases -->
    <section class="phrases-section" aria-label="Quick phrases">
      <div class="section-label">Quick phrases</div>
      <div class="phrases-grid" id="phrases-grid"></div>
    </section>

    <!-- Gesture history -->
    <section class="history-section" aria-label="Recent gestures">
      <div class="section-label">Recent gestures</div>
      <div class="gesture-history" id="gesture-history">
        <p class="empty-hint">Detected gestures will appear here.</p>
      </div>
    </section>

  </main>

  <!-- ── TTS Speed overlay (bottom right) ── -->
  <div class="tts-panel" aria-label="Voice speed control">
    <label for="tts-rate" class="tts-label"><i class="ti ti-microphone"></i> Speed</label>
    <input type="range" id="tts-rate" min="0.5" max="2" step="0.1" value="1" aria-label="Speech rate" />
    <span id="tts-rate-val">1.0×</span>
  </div>

  <!-- Scripts -->
  <script src="js/storage.js"></script>
  <script src="js/tts.js"></script>
  <script src="js/gestures.js"></script>
  <script src="js/phrases.js"></script>
  <script src="js/camera.js"></script>
  <script src="js/app.js"></script>

</body>
</html>
